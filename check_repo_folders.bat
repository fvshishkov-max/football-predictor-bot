@echo off
chcp 1251 >nul
title Проверка папок в репозитории
color 0A

echo ========================================
====
echo 🔍 ПРОВЕРКА ПАПОК В РЕПОЗИТОРИИ
echo ========================================
====
echo.

REM ========================================
REM 1. Смотрим историю изменений
REM ========================================
echo 1. ПОСЛЕДНИЕ ИЗМЕНЕНИЯ:
echo ------------------------
git log --name-status -5
echo.

REM ========================================
REM 2. Какие папки были удалены
REM ========================================
echo 2. УДАЛЕННЫЕ ПАПКИ (за последние 10 коммитов):
echo ----------------------------------------------
git log --diff-filter=D --summary | findstr "delete"
echo.

REM ========================================
REM 3. Текущее состояние папок
REM ========================================
echo 3. ТЕКУЩИЕ ПАПКИ В РЕПОЗИТОРИИ:
echo --------------------------------
git ls-tree -r main --name-only | findstr /r ".*/" | sort | uniq
echo.

REM ========================================
REM 4. Сравнение с локальными папками
REM ========================================
echo 4. ЛОКАЛЬНЫЕ ПАПКИ:
echo --------------------
dir /ad /b
echo.

REM ========================================
REM 5. Проверка .gitignore
REM ========================================
echo 5. СОДЕРЖИМОЕ .GITIGNORE:
echo --------------------------
if exist .gitignore (
    type .gitignore
) else (
    echo .gitignore не найден
)
echo.

REM ========================================
REM 6. Проверка индекса
REM ========================================
echo 6. ФАЙЛЫ В ИНДЕКСЕ:
echo --------------------
git ls-files
echo.

echo ========================================
====
echo АНАЛИЗ:
echo ========================================
====

REM Проверяем, есть ли папки в .gitignore
if exist .gitignore (
    findstr /i "data" .gitignore >nul
    if errorlevel 1 (
        echo   ⚠️ Папка data НЕ в .gitignore
    ) else (
        echo   ✅ Папка data в .gitignore
    )
    
    findstr /i "archives" .gitignore >nul
    if errorlevel 1 (
        echo   ⚠️ Папка archives НЕ в .gitignore
    ) else (
        echo   ✅ Папка archives в .gitignore
    )
)

echo.
echo ========================================
====
pause