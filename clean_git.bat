@echo off
chcp 65001 >nul
title Очистка Git
color 0A

echo ========================================
echo 🧹 ОЧИСТКА GIT ИНДЕКСА
echo ========================================
echo.

echo 1. Удаление файлов из индекса...
git rm -r --cached . >nul 2>nul

echo 2. Добавление файлов заново...
git add .

echo 3. Проверка статуса:
git status

echo.
echo ========================================
echo ✅ Готово! Теперь можно сделать коммит
echo ========================================
pause