@echo off
chcp 1251 >nul
title Загрузка из GitHub
color 0A

echo ========================================
====
echo 📥 ЗАГРУЗКА ИЗ GITHUB
echo ========================================
====
echo.

echo 1. Сохранение локальных изменений (stash)...
echo --------------------------------------------
git stash
