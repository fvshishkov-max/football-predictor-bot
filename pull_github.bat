git pull origin main
echo.

echo 3. Восстановление локальных изменений...
echo -----------------------------------------
git stash pop
echo.

echo ========================================
====
echo ✅ ЗАГРУЗКА ЗАВЕРШЕНА
echo ========================================
====
pause